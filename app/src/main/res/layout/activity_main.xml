<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VPN OnOff"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="连接目标 WiFi 时关闭 VPN\n断开或连接其他 WiFi 时开启 VPN"
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VPN 客户端"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/clientSpinner"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/current_wifi_label"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/currentSsidText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/wifi_not_connected"
        android:textSize="16sp"
        android:textColor="#212121"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/setTargetButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/set_as_target"
            android:textSize="13sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/clearTargetButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/clear_target"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/target_ssid_label"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/targetSsidText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_target"
        android:textSize="15sp"
        android:textColor="#424242"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="服务已停止"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#F44336"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/wifiStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WiFi: 检测中..."
        android:textSize="15sp"
        android:textColor="#424242"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/shizukuStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shizuku: 检测中..."
        android:textSize="13sp"
        android:textColor="#FF9800"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/bgPopupStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="后台弹出界面: 检测中..."
        android:textSize="13sp"
        android:textColor="#FF9800"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/toggleButton"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="开始监听"
        android:textSize="16sp" />

</LinearLayout>
